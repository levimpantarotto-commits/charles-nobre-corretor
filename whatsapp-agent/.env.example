# =============================
# Evolution API (rodando no Coolify)
# =============================
EVOLUTION_API_URL=https://evolution.levimp.com.br
EVOLUTION_API_KEY=                     # admin key (gerada no setup do Evolution)
EVOLUTION_INSTANCE_NAME=charles-nobre  # nome da instancia do Charles

# Token compartilhado entre Evolution e este servico (webhook auth)
WEBHOOK_TOKEN=                          # gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# =============================
# Supabase do Charles
# =============================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# =============================
# Cerebro conversacional (Groq)
# =============================
GROQ_API_KEY=                           # https://console.groq.com/keys
GROQ_MODEL=llama-3.3-70b-versatile      # ou llama-3.1-8b-instant pra mais barato

# Opcional: fallback Gemini se Groq cair
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# =============================
# Google Sheets (lista de leads)
# =============================
GOOGLE_SERVICE_ACCOUNT_JSON=            # caminho do arquivo OU JSON inline base64
GOOGLE_SHEETS_LEADS_ID=                 # ID da planilha (parte do URL: docs.google.com/spreadsheets/d/<ID>/edit)
GOOGLE_SHEETS_LEADS_RANGE=Leads!A:F     # aba e range

# =============================
# Charles - DNA do corretor (system prompt)
# =============================
CHARLES_NOME=Charles R. Nobre
CHARLES_CRECI=37177
CHARLES_WHATSAPP=+5548999459527
CHARLES_REGIAO=Imbituba, Garopaba e Imaruí (SC)
CHARLES_TOM=Profissional, direto, acolhedor. Trata o lead pelo nome. Nunca usa emoji exagerado.

# =============================
# Server
# =============================
PORT=3030
LOG_LEVEL=info                          # info | debug
ALLOWED_PHONES=                          # csv de numeros que podem disparar broadcast (admin). Vazio = todos.
